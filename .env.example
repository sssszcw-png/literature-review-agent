# LLM API (any OpenAI-compatible provider)
# For DeepSeek:  LLM_API_KEY=sk-...  LLM_BASE_URL=https://api.deepseek.com    LLM_MODEL=deepseek-chat
# For OpenAI:    LLM_API_KEY=sk-...  LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o
# For Groq:      LLM_API_KEY=gsk_... LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-4-8b
# For Ollama:    LLM_API_KEY=ollama  LLM_BASE_URL=http://localhost:11434/v1    LLM_MODEL=llama3
LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=4096
# LLM_REQUEST_TIMEOUT=120

# Backward compatible: DEEPSEEK_API_KEY, DEEPSEEK_BASE_URL, DEEPSEEK_MODEL also work
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Semantic Scholar (free, no key required)
# SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
# SEMANTIC_SCHOLAR_RATE_LIMIT=1.0

# arXiv (free, no key required)
# ARXIV_BASE_URL=https://export.arxiv.org/api/query

# Search
# SEARCH_MAX_RESULTS_PER_QUERY=20
# SEARCH_TIMEOUT=30

# PDF Processing
# PDF_CACHE_DIR=cache/papers
# PDF_PARSE_TIMEOUT=120
# PDF_MAX_SIZE_MB=50

# Agent Behavior
# DEFAULT_MAX_ROUNDS=5
# SATURATION_THRESHOLD=0.7
# MAX_NO_IMPROVEMENT_ROUNDS=2
# MAX_CONCURRENT_SEARCHES=5
# MAX_CONCURRENT_CHAPTERS=5
# MAX_PAPERS_PER_ROUND=50

# Output
# DEFAULT_OUTPUT_DIR=reports

# Retry
# RETRY_MAX_ATTEMPTS=3
# RETRY_BACKOFF_BASE=2.0
# RETRY_MAX_DELAY=60.0

# Checkpoint
# CHECKPOINT_DIR=checkpoints
# CHECKPOINT_ENABLED=true

# Logging
# LOG_LEVEL=INFO
